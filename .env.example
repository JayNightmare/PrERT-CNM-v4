# Copy this file to .env and fill in the values for Chroma-backed workflows.
# Phase 2, Phase 3, and Phase 4 work can be developed independently from Chroma,
# but Phase 1 extraction and migration commands expect these settings when you
# are targeting a live Chroma environment.
# PrivacyBERT runs also auto-load this file from the repository root, so set
# HF_TOKEN here before the first authenticated Hugging Face model download.

CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
CHROMA_COLLECTION_NAME=ground_truth

HF_TOKEN=